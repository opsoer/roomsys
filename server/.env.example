# Database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=rental

# JWT
JWT_SECRET=your_random_secret_key_here

# Server
SERVER_PORT=8081
GIN_MODE=debug

# Upload
UPLOAD_DIR=./storage/media

# Logging
LOG_LEVEL=info
LOG_DIR=./logs

# Qiniu Cloud Storage
QINIU_ACCESS_KEY=your_access_key
QINIU_SECRET_KEY=your_secret_key
QINIU_BUCKET=roomsys
QINIU_DOMAIN=your_domain
QINIU_USE_HTTPS=false
QINIU_ZONE=z2
